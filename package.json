{
  "name": "launchpromptly",
  "version": "1.0.0-rc.1",
  "description": "LaunchPromptly Node.js SDK — thin trust boundary for LLM apps (rule-based detection in-process; ML runs in the launchpromptly-scanner sidecar)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rahuliiitm/launchpromptly-node-sdk"
  },
  "keywords": [
    "launchpromptly",
    "llm-security",
    "pii-redaction",
    "prompt-injection",
    "cost-guard",
    "llm",
    "ai",
    "openai",
    "anthropic",
    "gemini",
    "content-filter",
    "guardrails",
    "sdk"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./ml": {
      "types": "./dist/ml/index.d.ts",
      "require": "./dist/ml/index.js",
      "import": "./dist/ml/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "require": "./dist/agent/index.js",
      "import": "./dist/agent/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "jest --passWithNoTests",
    "test:integration": "tsx tests/integration-test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@launchpromptly/mcp-core": "file:../launchpromptly-mcp-core",
    "@opentelemetry/api": "^1.9.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0"
  }
}
